# Airtable — create a restricted token with:
#   Read:  1:1 Sessions table, Spieler table
#   Write: 1:1 Sessions table (Download PDF field + Anhänge attachment field)
# Scopes needed: data.records:read, data.records:write
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX

# Base ID (already known)
AIRTABLE_BASE_ID=appfHYZLOiuQC5Gca

# Random secret for signing download tokens (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-32-char-secret-here

# Webhook security header — set the same value in Airtable automation
WEBHOOK_SECRET=your-webhook-secret-here

# Set this after Vercel deployment
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- /architektur Passwortschutz -------------------------------------------
# Schuetzt NUR die /architektur-Seite (ein gemeinsames Passwort).
# Lange Passphrase waehlen. Aendern = alle bestehenden Logins werden ungueltig.
# Ohne diese Variable ist die Seite gesperrt (zeigt Konfig-Hinweis).
ARCHITEKTUR_PASSWORD=eine-lange-geheime-passphrase
